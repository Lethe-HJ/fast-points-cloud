{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@mini-three/types": ["../types/src/index.ts"]
    },
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
